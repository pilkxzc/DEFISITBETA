# ──────────────────────────────────────────────
#  DEFIS Server — environment variables
#  Copy to .env and fill in real values
# ──────────────────────────────────────────────

# Port the server listens on (default: 3717)
DEFIS_PORT=3717

# Host/interface to bind (0.0.0.0 = all interfaces)
DEFIS_HOST=0.0.0.0

# REQUIRED in production — change to a long random string!
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
DEFIS_JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_HERE

# Path to SQLite database file (default: ./defis.db)
# DEFIS_DB=/var/lib/defis/defis.db

# Extra allowed CORS origins (comma-separated), leave empty for Electron-only
# DEFIS_ALLOWED_ORIGINS=
