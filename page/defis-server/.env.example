# DEFIS Server Configuration

# Host and Port
DEFIS_HOST=0.0.0.0
DEFIS_PORT=3717

# Database Path (default: ./defis.db)
# DEFIS_DB=/path/to/your/database.db

# JWT Secret Key (CRITICAL: Change this to a random string in production!)
DEFIS_JWT_SECRET=your_super_secret_random_string_here

# Allowed CORS Origins (comma separated)
# DEFIS_ALLOWED_ORIGINS=http://localhost:3000,https://app.defis.app
